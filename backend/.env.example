# Server
PORT=5050
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# Database — Neon Postgres (Dashboard → Connection string → copy " pooled " or direct URI)
# Example: postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# Auth
JWT_SECRET=replace-with-a-long-random-secret-string-min-32-chars
JWT_EXPIRES_IN=7d

# AI — prefer OpenRouter (credit balance; avoids Gemini free-tier limits). Model IDs: https://openrouter.ai/models
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash
OPENROUTER_IMAGE_MODEL=google/gemini-2.5-flash-image
# Optional OpenRouter attribution (recommended on deploy)
OPENROUTER_SITE_URL=https://your-production-domain.vercel.app
OPENROUTER_APP_TITLE=Zebvo

# Legacy: direct Google Gemini SDK (optional if OPENROUTER_API_KEY is set)
GEMINI_API_KEY=
GEMINI_TEXT_MODEL=gemini-2.0-flash
GEMINI_IMAGE_MODEL=gemini-2.0-flash-exp-image-generation
