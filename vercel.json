{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "experimentalServices": {
    "frontend": {
      "entrypoint": "frontend",
      "routePrefix": "/",
      "framework": "nextjs"
    },
    "backend": {
      "entrypoint": "backend",
      "routePrefix": "/api",
      "framework": "express",
      "maxDuration": 300,
      "includeFiles": [
        "node_modules/.prisma/**",
        "node_modules/@prisma/client/**",
        "backend/node_modules/.prisma/**",
        "backend/node_modules/@prisma/client/**"
      ]
    }
  }
}
